# C++ 소스는 UTF-8 BOM + CRLF (프로젝트 코딩 규약)
*.cpp text eol=crlf
*.hpp text eol=crlf
*.h   text eol=crlf
*.inl text eol=crlf

# 빌드/스크립트는 LF (Linux 친화)
*.cmake          text eol=lf
CMakeLists.txt   text eol=lf
Dockerfile       text eol=lf
*.yml            text eol=lf
*.yaml           text eol=lf
*.sh             text eol=lf

# 문서는 LF (GitHub 권장)
*.md             text eol=lf
LICENSE          text eol=lf

# Windows 배치는 CRLF
*.bat            text eol=crlf
*.cmd            text eol=crlf

# 바이너리 (line ending 변환 금지)
*.png            binary
*.jpg            binary
*.ico            binary
*.exe            binary
*.dll            binary
*.so             binary
